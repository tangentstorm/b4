MODULE Test;
  VAR i, sum, r: INTEGER;

  PROCEDURE Add(a, b: INTEGER): INTEGER;
  BEGIN RETURN a + b
  END Add;

  PROCEDURE Fact(n: INTEGER): INTEGER;
    VAR result: INTEGER;
  BEGIN
    result := 1;
    WHILE n > 1 DO
      result := result * n;
      DEC(n)
    END;
    RETURN result
  END Fact;

BEGIN
  i := 1;
  sum := 0;
  WHILE i <= 10 DO
    sum := sum + i;
    INC(i)
  END;
  r := Add(sum, Fact(5));
  (* r should be 55 + 120 = 175 *)

  (* Write 'OK' to stdout using b4 io *)
  (* This needs SYSTEM-level access which we don't have yet *)
  (* For now, result is just in memory at global var r *)
  r := Fact(6)
  (* r should be 720 *)
END Test.
